{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "UpdatePackage": {
    "SevenZipPath": "7z",
    "BackupRoot": "update-backups",
    "HistoryFile": "update-history.json"
  },
  "ProcessConfig": [
    {
      "Id": "data-collector-01",
      "Name": "频谱数据采集服务",
      "DllPath": "Collector.dll",
      "Arguments": "--port 5001",
      "StartupDelayMs": 3000
    },
    {
      "Id": "signal-analyzer-01",
      "Name": "IQ 信号离线分析服务",
      "DllPath": "Analyzer.dll",
      "Arguments": "--port 5002",
      "StartupDelayMs": 5000
    }
  ]
}
